{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": false,
    "isolatedDeclarations": false,
    "paths": {
      "ua-compass": ["./src/index.ts"]
    },
    "types": ["vitest/globals", "node"]
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "benchmarks/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": ["src/cli.ts"]
}
