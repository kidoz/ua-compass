    "declaration": false,
    "isolatedDeclarations": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "benchmarks",
    "outDir": ".benchmark-results/runner",
    "types": ["node"]
  },
  "include": [
    "benchmarks/lib.ts",
    "benchmarks/run.ts",
